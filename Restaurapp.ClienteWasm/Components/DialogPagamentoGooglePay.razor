@implements IAsyncDisposable
@using System.Globalization
@inject IJSRuntime JSRuntime
@inject ContaMesaService ContaMesaService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Formas de pagamento</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.body1">
                Selecione uma forma de pagamento para concluir a conta.
            </MudText>

            <MudPaper Class="pa-3" Outlined="true">
                <MudText Typo="Typo.subtitle2">Conta #@ContaMesaId</MudText>
                <MudText Typo="Typo.h6">Total: @Total.ToString("C2", culturaPtBr)</MudText>
            </MudPaper>

            <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                No momento, a única opção disponível é o Google Pay.
            </MudAlert>

            @if (!string.IsNullOrWhiteSpace(_mensagemStatus))
            {
                <MudAlert Severity="@(_processando? Severity.Info: Severity.Warning)" Dense="true"
                          Variant="Variant.Outlined">
                    @_mensagemStatus
                </MudAlert>
            }

            <div id="@_googlePayContainerId" style="min-height: 48px; display: flex; justify-content: center;"></div>

            @if (_processando)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <MudText Typo="Typo.body2">Processando pagamento...</MudText>
                </MudStack>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Disabled="@_processando">Cancelar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public int ContaMesaId { get; set; }

    [Parameter]
    public decimal Total { get; set; }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private readonly CultureInfo culturaPtBr = new("pt-BR");
    private readonly string _googlePayContainerId = $"google-pay-button-{Guid.NewGuid():N}";
    private DotNetObjectReference<DialogPagamentoGooglePay>? _dotNetRef;
    private bool _processando;
    private string? _mensagemStatus;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            var config = await ContaMesaService.ObterGooglePayConfigAsync();
            if (config is null)
            {
                throw new InvalidOperationException("Não foi possível carregar a configuração do Google Pay.");
            }

            await JSRuntime.InvokeVoidAsync("googlePayInterop.renderButton", _googlePayContainerId, config, _dotNetRef);
        }
        catch (Exception ex)
        {
            _mensagemStatus = $"Não foi possível carregar o Google Pay: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public Task OnGooglePayStatusChanged(string message)
    {
        _mensagemStatus = message;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnGooglePayAuthorized(string token)
    {
        if (_processando)
        {
            return;
        }

        _processando = true;
        _mensagemStatus = null;
        await InvokeAsync(StateHasChanged);

        var resultado = await ContaMesaService.ProcessarPagamentoGooglePayAsync(token);
        if (!resultado.Success || resultado.Resultado?.Sucesso != true)
        {
            _processando = false;
            _mensagemStatus = resultado.ErrorMessage ?? resultado.Resultado?.Mensagem ?? "Não foi possível processar o pagamento.";
            Snackbar.Add(_mensagemStatus, Severity.Error);
            await InvokeAsync(StateHasChanged);
            return;
        }

        var mensagem = string.IsNullOrWhiteSpace(resultado.Resultado.Referencia)
            ? resultado.Resultado.Mensagem
            : $"{resultado.Resultado.Mensagem} Referência: {resultado.Resultado.Referencia}";

        Snackbar.Add(mensagem, Severity.Success);
        MudDialog.Close(DialogResult.Ok(resultado.Resultado));
    }

    [JSInvokable]
    public Task OnGooglePayError(string message)
    {
        _processando = false;

        if (!string.IsNullOrWhiteSpace(message)
            && !message.Contains("cancel", StringComparison.OrdinalIgnoreCase)
            && !message.Contains("cancelado", StringComparison.OrdinalIgnoreCase))
        {
            _mensagemStatus = message;
        }

        return InvokeAsync(StateHasChanged);
    }

    private void Cancelar() => MudDialog.Cancel();

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("googlePayInterop.clear", _googlePayContainerId);
        }
        catch
        {
        }

        _dotNetRef?.Dispose();
    }
}