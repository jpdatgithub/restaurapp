@page "/carrinho"
@using System.Globalization

@inject CarrinhoService CarrinhoService
@inject PedidosService PedidosService
@inject NavigationManager Navigation
@inject IDialogService DialogService

<PageTitle>Carrinho</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Carrinho</MudText>

@if (carregando)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (!snapshot.Itens.Any())
{
    <MudAlert Severity="Severity.Info">Seu carrinho está vazio.</MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="IrParaHome">
        Ver empresas
    </MudButton>
}
else
{
    <MudText Typo="Typo.subtitle1" Class="mb-3">Empresa: @snapshot.EmpresaNome</MudText>

    @if (!string.IsNullOrWhiteSpace(mensagem))
    {
        <MudAlert Severity="@mensagemSeverity" Dense="true" Class="mb-3">@mensagem</MudAlert>
    }

    <MudTable Items="snapshot.Itens" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Produto</MudTh>
            <MudTh>Preço</MudTh>
            <MudTh>Quantidade</MudTh>
            <MudTh>Subtotal</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Produto">
                <div>@context.NomeProduto</div>
                @if (context.OpcoesSelecionadas.Any())
                {
                    @foreach (var opcao in context.OpcoesSelecionadas.OrderBy(o => o.NomeSecao).ThenBy(o => o.NomeOpcao))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @opcao.NomeSecao: @opcao.NomeOpcao x@opcao.Quantidade
                        </MudText>
                    }
                }
            </MudTd>
            <MudTd DataLabel="Preço">@context.PrecoUnitario.ToString("C", culturaPtBr)</MudTd>
            <MudTd DataLabel="Quantidade">
                <MudNumericField T="int" Value="@context.Quantidade"
                                 ValueChanged="(novaQuantidade) => AtualizarQuantidadeAsync(context.ItemKey, novaQuantidade)" Min="1"
                                 Max="99" Immediate="true" HideSpinButtons="false" Style="width: 100px;" />
            </MudTd>
            <MudTd DataLabel="Subtotal">@((context.PrecoUnitario * context.Quantidade).ToString("C", culturaPtBr))</MudTd>
            <MudTd DataLabel="Ações">
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                           OnClick="() => RemoverItemAsync(context.ItemKey)">
                    Remover
                </MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudCard Class="mt-4">
        <MudCardContent>
            <MudText Typo="Typo.h6">Finalizar pedido</MudText>
            <MudSelect T="TipoAtendimentoCheckout" Value="tipoAtendimento" ValueChanged="AoAlterarTipoAtendimento"
                       Label="Tipo de atendimento" Variant="Variant.Outlined" Class="mt-2">
                <MudSelectItem Value="TipoAtendimentoCheckout.Entrega">Entrega</MudSelectItem>
                <MudSelectItem Value="TipoAtendimentoCheckout.Retirada">Takeaway (retirada no local)</MudSelectItem>
            </MudSelect>

            @if (tipoAtendimento == TipoAtendimentoCheckout.Entrega)
            {
                <MudTextField T="string" @bind-Value="enderecoEntrega" Label="Endereço de entrega" Variant="Variant.Outlined"
                              Class="mt-2" />
            }

            <MudTextField T="string" @bind-Value="observacoes" Label="Observações" Variant="Variant.Outlined" Lines="3"
                          Class="mt-2" />

            <MudDivider Class="my-3" />
            <MudText Typo="Typo.body1"><strong>Subtotal:</strong> @snapshot.Subtotal.ToString("C", culturaPtBr)</MudText>
            <MudText Typo="Typo.body1"><strong>Total:</strong> @snapshot.Subtotal.ToString("C", culturaPtBr)</MudText>

            <MudStack Row="true" Spacing="2" Class="mt-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="FinalizarPedidoAsync"
                           Disabled="@finalizando">
                    @if (finalizando)
                    {
                        <span>Finalizando...</span>
                    }
                    else
                    {
                        <span>Finalizar pedido</span>
                    }
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="LimparCarrinhoAsync">
                    Limpar carrinho
                </MudButton>
            </MudStack>
        </MudCardContent>
    </MudCard>
}

@code {
    private static readonly CultureInfo culturaPtBr = CultureInfo.GetCultureInfo("pt-BR");

    private bool carregando = true;
    private bool finalizando;
    private string? mensagem;
    private Severity mensagemSeverity = Severity.Info;
    private CarrinhoSnapshot snapshot = new();
    private TipoAtendimentoCheckout tipoAtendimento = TipoAtendimentoCheckout.Entrega;
    private string? enderecoEntrega;
    private string? observacoes;

    protected override async Task OnInitializedAsync()
    {
        await RecarregarCarrinhoAsync();
    }

    private async Task RecarregarCarrinhoAsync()
    {
        carregando = true;
        snapshot = await CarrinhoService.GetSnapshotAsync();
        carregando = false;
    }

    private async Task AtualizarQuantidadeAsync(string itemKey, int quantidade)
    {
        await CarrinhoService.UpdateQuantidadeAsync(itemKey, quantidade);
        snapshot = await CarrinhoService.GetSnapshotAsync();
    }

    private async Task RemoverItemAsync(string itemKey)
    {
        await CarrinhoService.RemoveItemAsync(itemKey);
        snapshot = await CarrinhoService.GetSnapshotAsync();
    }

    private async Task LimparCarrinhoAsync()
    {
        await CarrinhoService.ClearAsync();
        snapshot = await CarrinhoService.GetSnapshotAsync();
    }

    private async Task FinalizarPedidoAsync()
    {
        if (!snapshot.Itens.Any())
        {
            mensagemSeverity = Severity.Warning;
            mensagem = "Seu carrinho está vazio.";
            return;
        }

        if (tipoAtendimento == TipoAtendimentoCheckout.Entrega && string.IsNullOrWhiteSpace(enderecoEntrega))
        {
            mensagemSeverity = Severity.Warning;
            mensagem = "Informe o endereço de entrega.";
            return;
        }

        var dialogParameters = new DialogParameters
        {
            [nameof(DialogPagamentoCheckoutGooglePay.EmpresaId)] = snapshot.EmpresaId,
            [nameof(DialogPagamentoCheckoutGooglePay.Total)] = snapshot.Subtotal
        };

        var dialogOptions = new DialogOptions
        {
            CloseButton = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<DialogPagamentoCheckoutGooglePay>(
            "Formas de pagamento",
            dialogParameters,
            dialogOptions);

        var pagamento = await dialog.Result;
        if (pagamento is null || pagamento.Canceled)
        {
            mensagemSeverity = Severity.Info;
            mensagem = "Pagamento cancelado. O pedido não foi finalizado.";
            return;
        }

        finalizando = true;
        mensagem = null;

        var request = new CheckoutPedidoRequest
        {
            EmpresaId = snapshot.EmpresaId,
            Takeaway = tipoAtendimento == TipoAtendimentoCheckout.Retirada,
            NumeroMesa = null,
            EnderecoEntrega = tipoAtendimento == TipoAtendimentoCheckout.Entrega ? enderecoEntrega : null,
            Observacoes = observacoes,
            Itens = snapshot.Itens
                .Select(i => new CheckoutPedidoItemRequest
                {
                    ProdutoId = i.ProdutoId,
                    Quantidade = i.Quantidade,
                    Opcoes = i.OpcoesSelecionadas
                        .Select(o => new CheckoutPedidoItemOpcaoRequest
                        {
                            ProdutoOpcaoId = o.ProdutoOpcaoId,
                            Quantidade = o.Quantidade
                        })
                        .ToList()
                })
                .ToList()
        };

        var resultado = await PedidosService.CheckoutAsync(request);
        finalizando = false;

        if (!resultado.Success || resultado.Pedido is null)
        {
            mensagemSeverity = Severity.Error;
            mensagem = resultado.ErrorMessage ?? "Não foi possível finalizar o pedido.";
            return;
        }

        await CarrinhoService.ClearAsync();
        snapshot = await CarrinhoService.GetSnapshotAsync();
        Navigation.NavigateTo("/meus-pedidos");
    }

    private void IrParaHome()
    {
        Navigation.NavigateTo("/");
    }

    private Task AoAlterarTipoAtendimento(TipoAtendimentoCheckout novoTipo)
    {
        tipoAtendimento = novoTipo;
        return Task.CompletedTask;
    }

    private enum TipoAtendimentoCheckout
    {
        Entrega,
        Retirada
    }
}