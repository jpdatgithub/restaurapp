@page "/profile"
@attribute [Authorize]

@inject ClienteAuthService AuthService

<PageTitle>Profile</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Perfil</MudText>

@if (carregando)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (perfil is null)
{
    <MudAlert Severity="Severity.Error">Não foi possível carregar o perfil.</MudAlert>
}
else
{
    @if (perfil.IsGuest)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3" Style="max-width: 520px;">
            Você está usando o modo convidado. Entrar com uma conta registrada continua sendo opcional.
        </MudAlert>
    }

    <MudCard Style="max-width: 520px;">
        <MudCardContent>
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Nome</MudText>
            <MudText Typo="Typo.h6">@perfil.Nome</MudText>
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Email</MudText>
            <MudText Typo="Typo.body1">@perfil.Email</MudText>
        </MudCardContent>
    </MudCard>
}

@code {
    private bool carregando = true;
    private ClienteProfileResponse? perfil;

    protected override async Task OnInitializedAsync()
    {
        perfil = await AuthService.GetProfileAsync();
        carregando = false;
    }
}