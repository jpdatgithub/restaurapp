    private RenderFragment RenderConteudoPedidosConta(ContaMesa conta) => @<div>
        @if (!ObterPedidosOrdenados(conta).Any())
        {
            <MudText Typo="Typo.body2" Class="mt-2">Nenhum pedido ativo vinculado a esta conta.</MudText>
        }
        else
        {
            @foreach (var pedidoConta in ObterPedidosOrdenados(conta))
            {
                <MudPaper Elevation="0" Class="pa-3 mt-3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle2">Pedido #@pedidoConta.Id</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                            @FormatarStatusParaExibicao(pedidoConta)
                        </MudChip>
                    </MudStack>
                    <MudText Typo="Typo.caption">@pedidoConta.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                    <MudText Typo="Typo.body2">Cliente: @pedidoConta.NomeClienteSnapshot</MudText>

                    <MudTable Items="pedidoConta.Itens" Dense="true" Hover="true" Elevation="0" Class="mt-2">
                        <HeaderContent>
                            <MudTh>Item</MudTh>
                            <MudTh Style="text-align: right">Qtd</MudTh>
                            <MudTh Style="text-align: right">Subtotal</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Item">
                                <div>@context.NomeProdutoSnapshot</div>
                                @if (context.OpcoesSelecionadas.Any())
                                {
                                    @foreach (var opcao in context.OpcoesSelecionadas.OrderBy(o => o.NomeSecaoSnapshot).ThenBy(o => o.NomeOpcaoSnapshot))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @opcao.NomeSecaoSnapshot: @opcao.NomeOpcaoSnapshot x@opcao.Quantidade
                                        </MudText>
                                    }
                                }
                            </MudTd>
                            <MudTd DataLabel="Qtd" Style="text-align: right">@context.Quantidade</MudTd>
                            <MudTd DataLabel="Subtotal" Style="text-align: right">@context.SubtotalItem.ToString("C2", culturaPtBr)</MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudText Typo="Typo.body2" Align="Align.Right">Total do pedido: @pedidoConta.Total.ToString("C2", culturaPtBr)</MudText>
                </MudPaper>
            }
        }
    </div>;

    private async Task PagarContaMesaAsync(int contaMesaId)
    {
        if (pagandoContaMesa)
        {
            return;
        }

        pagandoContaMesa = true;

        try
        {
            var conta = await PedidoService.ObterContaMesaDetalhadaAsync(contaMesaId);
            if (conta is null)
            {
                Snackbar.Add("Não foi possível localizar a conta selecionada.", Severity.Warning);
                return;
            }

            var totalConta = ObterTotalConta(conta);
            if (totalConta <= 0)
            {
                Snackbar.Add("Não há itens pendentes para pagamento nesta conta.", Severity.Info);
                return;
            }

            var dialog = await DialogService.ShowAsync<ConfirmarPagamentoDialog>(
                "Confirmar pagamento",
                options: new DialogOptions
                {
                    CloseOnEscapeKey = true,
                    MaxWidth = MaxWidth.ExtraSmall,
                    FullWidth = true,
                    BackdropClick = false
                });

            var confirmarPagamento = await dialog.Result;
            if (confirmarPagamento is null || confirmarPagamento.Canceled)
            {
                return;
            }

            var pagamentoRegistrado = await PedidoService.FecharContaMesaAsync(contaMesaId);
            if (!pagamentoRegistrado)
            {
                Snackbar.Add("Não foi possível confirmar o pagamento desta conta.", Severity.Error);
                return;
            }

            if (contaDetalheSelecionada?.Id == contaMesaId)
            {
                contaDetalheSelecionada = null;
            }

            Snackbar.Add("Pagamento confirmado com sucesso.", Severity.Success);
            await CarregarContasAsync();
        }
        finally
        {
            pagandoContaMesa = false;
        }
    }

    private List<MesaAgrupadaViewModel> ObterMesasAgrupadasFiltradas()
    {
        var mesas = mesasAgrupadasAbertas;

        if (string.IsNullOrWhiteSpace(filtroContas))
        {
            return mesas;
        }

        var termo = filtroContas.Trim();

        return mesas
            .Where(m =>
                m.NumeroMesa.Contains(termo, StringComparison.OrdinalIgnoreCase)
                || ObterResumoClientesMesa(m).Contains(termo, StringComparison.OrdinalIgnoreCase)
                || m.Contas.Any(c => c.Id.ToString().Contains(termo, StringComparison.OrdinalIgnoreCase)))
            .OrderByDescending(m => m.UpdatedAtUtc)
            .ThenBy(m => m.NumeroMesa)
            .ToList();
    }

    private List<ContaMesa> ObterContasAbertasFiltradas()
    {
        return ObterContasFiltradas(StatusContaMesa.Aberta);
    }

    private List<ContaMesa> ObterTodasContasFiltradas()
    {
        return ObterContasFiltradas();
    }

    private List<ContaMesa> ObterContasFiltradas(StatusContaMesa? status = null)
    {
        var contasBase = todasContas.AsEnumerable();

        if (status.HasValue)
        {
            contasBase = contasBase.Where(c => c.Status == status.Value);
        }

        if (string.IsNullOrWhiteSpace(filtroTodasContas))
        {
            return contasBase
                .OrderByDescending(c => c.UpdatedAtUtc)
                .ThenByDescending(c => c.CreatedAtUtc)
                .ToList();
        }

        var termo = filtroTodasContas.Trim();

        return contasBase
            .Where(c =>
                c.NumeroMesa.Contains(termo, StringComparison.OrdinalIgnoreCase)
                || c.Id.ToString().Contains(termo, StringComparison.OrdinalIgnoreCase)
                || ObterResumoClientesConta(c).Contains(termo, StringComparison.OrdinalIgnoreCase)
                || ObterTituloConta(c).Contains(termo, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(c => c.UpdatedAtUtc)
            .ThenByDescending(c => c.CreatedAtUtc)
            .ToList();
    }

    private static List<MesaAgrupadaViewModel> CriarMesasAgrupadas(IEnumerable<ContaMesa> contas)
    {
        return contas
            .GroupBy(c => c.NumeroMesa, StringComparer.OrdinalIgnoreCase)
            .Select(grupo => new MesaAgrupadaViewModel
            {
                NumeroMesa = grupo.First().NumeroMesa,
                Contas = grupo
                    .OrderByDescending(c => c.UpdatedAtUtc)
                    .ThenByDescending(c => c.CreatedAtUtc)
                    .ToList(),
                UpdatedAtUtc = grupo.Max(c => c.UpdatedAtUtc)
            })
            .OrderByDescending(m => m.UpdatedAtUtc)
            .ThenBy(m => m.NumeroMesa)
            .ToList();
    }

    private static List<Pedido> ObterPedidosOrdenados(ContaMesa conta)
    {
        return conta.Pedidos
            .Where(p => p.Status != StatusPedido.Cancelado && p.Status != StatusPedido.Criado)
            .OrderBy(p => p.CreatedAtUtc)
            .ToList();
    }

    private static int ObterQuantidadePedidosConta(ContaMesa conta)
    {
        return ObterPedidosOrdenados(conta).Count;
    }

    private static decimal ObterTotalConta(ContaMesa conta)
    {
        return conta.Pedidos
            .Where(p => p.Status != StatusPedido.Cancelado)
            .Sum(p => p.Total);
    }

    private static int ObterQuantidadePedidosMesa(MesaAgrupadaViewModel mesa)
    {
        return mesa.Contas.Sum(ObterQuantidadePedidosConta);
    }

    private static decimal ObterTotalMesa(MesaAgrupadaViewModel mesa)
    {
        return mesa.Contas.Sum(ObterTotalConta);
    }

    private static string ObterResumoClientesMesa(MesaAgrupadaViewModel mesa)
    {
        var nomes = mesa.Contas
            .Select(ObterNomePrincipalConta)
            .Where(n => !string.IsNullOrWhiteSpace(n) && n != "-")
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(3)
            .ToList();

        if (!nomes.Any())
        {
            return "-";
        }

        var resumo = string.Join(", ", nomes);
        var totalNomes = mesa.Contas
            .Select(ObterNomePrincipalConta)
            .Where(n => !string.IsNullOrWhiteSpace(n) && n != "-")
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();

        return totalNomes > nomes.Count ? $"{resumo}..." : resumo;
    }

    private static string ObterResumoClientesConta(ContaMesa conta)
    {
        return ObterNomePrincipalConta(conta);
    }

    private static string ObterTituloConta(ContaMesa conta)
    {
        var nomePrincipal = ObterNomePrincipalConta(conta);

        return string.IsNullOrWhiteSpace(nomePrincipal) || nomePrincipal == "-"
            ? $"Conta #{conta.Id}"
            : $"Conta de {nomePrincipal}";
    }

    private static string ObterNomePrincipalConta(ContaMesa conta)
    {
        var nomePrincipal = ObterPedidosOrdenados(conta)
            .Select(p => p.NomeClienteSnapshot?.Trim())
            .FirstOrDefault(n => !string.IsNullOrWhiteSpace(n));

        return string.IsNullOrWhiteSpace(nomePrincipal) ? "-" : nomePrincipal;
    }

    private static string FormatarStatusParaExibicao(Pedido pedido)
    {
        if (pedido.TipoAtendimento == TipoAtendimentoPedido.ComerAqui && pedido.Status == StatusPedido.Enviado)
        {
            return "Saiu para a mesa";
        }

        return pedido.Status switch
        {
            StatusPedido.Criado => "Criado",
            StatusPedido.Confirmado => "Confirmado",
            StatusPedido.EmPreparacao => "Em preparação",
            StatusPedido.Enviado => "Enviado",
            StatusPedido.Concluido => "Concluído",
            StatusPedido.Cancelado => "Cancelado",
            _ => pedido.Status.ToString()
        };
    }

    public ValueTask DisposeAsync()
    {
        if (_assinaturaAtualizacao is not null)
        {
            CanalAtualizacaoPedidos.PedidoAtualizado -= _assinaturaAtualizacao;
        }

        return ValueTask.CompletedTask;
    }

    private sealed class MesaAgrupadaViewModel
    {
        public string NumeroMesa { get; set; } = string.Empty;
        public List<ContaMesa> Contas { get; set; } = new();
        public DateTime UpdatedAtUtc { get; set; }
    }
}