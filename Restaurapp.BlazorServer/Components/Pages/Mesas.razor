            <MudText Typo="Typo.h6">Mesa @mesa.NumeroMesa</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @mesa.Contas.Count conta(s) ativa(s) • @ObterQuantidadePedidosMesa(mesa) pedido(s)
            </MudText>

            @foreach (var conta in mesa.Contas.OrderByDescending(c => c.UpdatedAtUtc).ThenByDescending(c => c.CreatedAtUtc))
            {
                <MudPaper Elevation="0" Class="pa-3 mt-3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.subtitle2">@ObterTituloConta(conta)</MudText>
                            <MudText Typo="Typo.caption">
                                Aberta em @conta.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </MudText>
                        </div>
                        <MudStack Row="true" Justify="Justify.FlexEnd">
                            <MudButton Variant="Variant.Text" Size="Size.Small"
