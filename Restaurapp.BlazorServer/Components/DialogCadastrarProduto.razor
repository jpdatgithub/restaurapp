@using Restaurapp.BlazorServer.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Cadastrar produto</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="success">
            <MudTabs Rounded="true" PanelClass="pt-3">
                <MudTabPanel Text="Básico" Icon="@Icons.Material.Filled.Inventory2">
                    @if (!novaSecao)
                    {
                        <MudSelect T="string" Label="Seção" Required="true" RequiredError="Selecione uma seção."
                                   @bind-Value="secaoSelecionada" @bind-Value:after="AoAlterarSecao">
                            @foreach (var secao in secoesDisponiveis)
                            {
                                <MudSelectItem T="string" Value="@secao">@secao</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        <MudTextField T="string" Label="Nova seção" Required="true" RequiredError="Informe a seção."
                                      MaxLength="20" Counter="20" @bind-Value="novaSecaoNome" />
                    }

                    <MudCheckBox T="bool" Class="mt-2" Label="Nova seção?" @bind-Value="novaSecao"
                                 @bind-Value:after="AoAlternarNovaSecao" />

                    @if (novaSecao)
                    {
                        <MudNumericField T="int?" Label="Ordem da seção no cardápio (opcional)" Variant="Variant.Outlined"
                                         Min="1" Immediate="true" HelperText="Use 1 para colocar a nova seção no topo do cardápio."
                                         Class="mt-3" @bind-Value="ordemSecaoNoCardapio" />
                    }

                    <MudTextField T="string" Label="Nome" Required="true" RequiredError="Informe o nome do produto."
                                  Class="mt-2" @bind-Value="nome" />

                    <MudTextField T="string" Label="Descrição (opcional)" Class="mt-3" @bind-Value="descricao" />

                    <MudNumericField T="decimal?" Label="Preço" Variant="Variant.Outlined" Min="0.01m"
                                     Adornment="Adornment.Start" AdornmentText="R$" Required="true"
                                     RequiredError="Informe o preço do produto." Class="mt-3" @bind-Value="preco" />

                    <MudNumericField T="int?" Label="Ordem no cardápio (opcional)" Variant="Variant.Outlined" Min="1"
                                     Immediate="true" HelperText="Use 1 para colocar o produto no topo da seção." Class="mt-3"
                                     @bind-Value="ordemNoCardapio" />
                </MudTabPanel>
                <MudTabPanel Text="Opções" Icon="@Icons.Material.Filled.Tune">
                    <ProdutoOpcoesEditor Secoes="opcoesSecoes" />
                </MudTabPanel>
            </MudTabs>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Salvar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public List<string> SecoesDisponiveis { get; set; } = new();

    [Parameter]
    public Dictionary<string, int> ProximasOrdensProdutoPorSecao { get; set; } = new(StringComparer.OrdinalIgnoreCase);

    [Parameter]
    public int ProximaOrdemSecaoSugerida { get; set; } = 1;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm? form;
    private bool success;
    private List<string> secoesDisponiveis = new();
    private bool novaSecao;
    private string? secaoSelecionada;
    private string? novaSecaoNome;
    private string nome = string.Empty;
    private string descricao = string.Empty;
    private decimal? preco;
    private int? ordemNoCardapio;
    private int? ordemSecaoNoCardapio;
    private List<ProdutoOpcaoSecaoEdicaoModel> opcoesSecoes = new();

    protected override void OnInitialized()
    {
        secoesDisponiveis = SecoesDisponiveis
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Select(s => s.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s)
            .ToList();

        secaoSelecionada = secoesDisponiveis.FirstOrDefault();
        ordemNoCardapio = ObterSugestaoOrdemProduto();
        ordemSecaoNoCardapio = ProximaOrdemSecaoSugerida > 0 ? ProximaOrdemSecaoSugerida : 1;
    }

    private void AoAlterarSecao()
    {
        if (!novaSecao)
        {
            ordemNoCardapio = ObterSugestaoOrdemProduto();
        }
    }

    private void AoAlternarNovaSecao()
    {
        ordemNoCardapio = ObterSugestaoOrdemProduto();

        if (novaSecao)
        {
            ordemSecaoNoCardapio ??= ProximaOrdemSecaoSugerida > 0 ? ProximaOrdemSecaoSugerida : 1;
        }
        else
        {
            ordemSecaoNoCardapio = null;
        }
    }

    private int ObterSugestaoOrdemProduto()
    {
        if (novaSecao)
        {
            return 1;
        }

        if (!string.IsNullOrWhiteSpace(secaoSelecionada)
            && ProximasOrdensProdutoPorSecao.TryGetValue(secaoSelecionada.Trim(), out var sugestao)
            && sugestao > 0)
        {
            return sugestao;
        }

        return 1;
    }

    private async Task Submit()
    {
        if (form is null)
        {
            return;
        }

        await form.ValidateAsync();

        var secao = novaSecao
            ? novaSecaoNome?.Trim()
            : secaoSelecionada?.Trim();

        int? ordemProdutoInformada = ordemNoCardapio is > 0 ? ordemNoCardapio.Value : null;
        int? ordemSecaoInformada = novaSecao && ordemSecaoNoCardapio is > 0
            ? ordemSecaoNoCardapio.Value
            : null;

        if (!success
            || preco is null
            || string.IsNullOrWhiteSpace(secao)
            || secao.Length > 20
            || string.IsNullOrWhiteSpace(nome)
            || (ordemNoCardapio.HasValue && ordemNoCardapio.Value < 1)
            || (novaSecao && ordemSecaoNoCardapio.HasValue && ordemSecaoNoCardapio.Value < 1))
        {
            return;
        }

        MudDialog.Close(DialogResult.Ok(new NovoProdutoDialogResult(
            secao,
            nome.Trim(),
            string.IsNullOrWhiteSpace(descricao) ? null : descricao.Trim(),
            preco.Value,
            ordemProdutoInformada,
            ordemSecaoInformada,
            opcoesSecoes.Select(s => s.Clone()).ToList())));
    }

    private void Cancel() => MudDialog.Cancel();

    public sealed record NovoProdutoDialogResult(
        string Secao,
        string Nome,
        string? Descricao,
        decimal Valor,
        int? OrdemProdutoInformada,
        int? OrdemSecaoInformada,
        List<ProdutoOpcaoSecaoEdicaoModel> OpcoesSecoes);
}