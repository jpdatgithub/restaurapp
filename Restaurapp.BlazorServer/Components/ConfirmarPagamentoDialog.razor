<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Confirmar pagamento?</MudText>
        <MudText Typo="Typo.body2" Class="mt-2">
            Esta ação irá marcar a conta como paga e finalizar seu fechamento.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Confirmar">Confirmar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private void Confirmar()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancelar()
    {
        MudDialog.Cancel();
    }
}